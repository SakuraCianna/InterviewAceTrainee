# Java API 与 Worker 镜像, 必须指向同一发布 commit
MIANBA_APP_IMAGE=mianba-java:replace_with_commit_sha

# 前端静态镜像, 发布时替换为同一 commit SHA
MIANBA_FRONTEND_IMAGE=mianba-frontend:replace_with_commit_sha

# 服务器 secret 目录, 目录权限必须为 0700
MIANBA_SECRETS_DIR=/srv/mianba/shared/secrets

# 服务器证书目录, 仅允许部署身份和 root 读取
MIANBA_CERTS_DIR=/srv/mianba/shared/certs

# 服务器稳定运行配置目录, 不随版本发布目录切换
MIANBA_RUNTIME_CONFIG_DIR=/srv/mianba/shared/runtime-config

# 正式环境允许跨域来源, 禁止使用星号
MIANBA_CORS_ALLOWED_ORIGINS=https://sakuracianna.icu,https://www.sakuracianna.icu

# API 数据库连接池上限, 4 GB 主机默认保持 6
API_DB_POOL_SIZE=6

# API 最小空闲数据库连接, 低流量环境默认保持 1
API_DB_MIN_IDLE=1

# Worker 数据库连接池上限, 单消费者默认保持 4
WORKER_DB_POOL_SIZE=4

# Worker 最小空闲数据库连接, 低流量环境默认保持 1
WORKER_DB_MIN_IDLE=1

# 数据库连接等待毫秒数, 快速失败以保护 Tomcat 线程
DB_CONNECTION_TIMEOUT_MS=5000

# API 最大工作线程数, 4 核主机默认保持 80
API_TOMCAT_MAX_THREADS=80

# API 等待队列长度, 防止恶意慢请求无限堆积
API_TOMCAT_ACCEPT_COUNT=40

# Worker 消费者并发数, 4 GB 主机默认保持 1
WORKER_CONSUMER_CONCURRENCY=1

# Worker 最大消费者并发数, 4 GB 主机默认保持 1
WORKER_CONSUMER_MAX_CONCURRENCY=1
