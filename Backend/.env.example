APP_NAME=面霸练习生
API_PREFIX=/api
ENVIRONMENT=runtime
# 单套运行配置：本机开发和服务器部署都使用这一套变量，只按实际地址改值。
# PostgreSQL 手动建库时使用 ENCODING 'UTF8'；PostgreSQL 的 UTF8 等价覆盖 MySQL utf8mb4 的 4 字节字符能力。
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/mianba
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sakuracianna.icu,https://www.sakuracianna.icu
ADMIN_ENTRY_PATH=/console-mianba
# 可登录后台的邮箱，多个邮箱用英文逗号分隔。
ADMIN_EMAIL_ALLOWLIST=your-admin@example.com
# Local HTTP needs false so registration/login can be tested end to end.
# Change to true after HTTPS is enabled on sakuracianna.icu.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ACCESS_TOKEN_SECRET=change-me-before-deploy
ACCESS_TOKEN_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_HASH_TARGET_MS=200

# 单套注册/登录流程：先请求邮箱验证码，再注册或登录。
# dev 表示验证码直接显示在接口返回里；resend 表示通过 Resend API 发送验证码。
EMAIL_PROVIDER=dev
EMAIL_FROM_NAME=面霸练习生
# 如果你的域名是 mianba.example.com，可填 no-reply@mianba.example.com；必须先在 Resend 验证该域名。
EMAIL_FROM_ADDRESS=no-reply@sakuracianna.icu
EMAIL_CODE_EXPIRE_SECONDS=600
EMAIL_CODE_RATE_LIMIT=5
EMAIL_CODE_RATE_WINDOW_SECONDS=600
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=

ZHIPU_API_KEY=
DEEPSEEK_API_KEY=
ALIYUN_BAILIAN_API_KEY=
VOLCENGINE_ARK_API_KEY=
# 不要把真实 API Key 提交到 Git；服务器上用系统环境变量或安全配置注入。
RESEND_API_KEY=
BREVO_API_KEY=
ALIYUN_DIRECTMAIL_ACCESS_KEY_ID=
ALIYUN_DIRECTMAIL_ACCESS_KEY_SECRET=
TENCENT_SES_SECRET_ID=
TENCENT_SES_SECRET_KEY=
